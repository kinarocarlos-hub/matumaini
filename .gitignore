# Coverage
coverage/

# Matumaini specific
# Database files (too large for git, user data)
*.sqlite
*.db
assets/data/*.json
assets/data/*.db

# MIDI files (large binary assets)
assets/midi/*.mid
assets/midi/*.midi

# Fonts and media (replace with your licensed assets)
assets/fonts/*
assets/rive/*
assets/images/*

# Exceptions for fonts dir itself
!assets/fonts/.gitkeep
!assets/rive/.gitkeep
!assets/images/.gitkeep
